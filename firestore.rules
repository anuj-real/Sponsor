rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all rule for this demo CRM application. 
    // Since the app uses client-side simulated sessions (SBR0001, SBR0005) 
    // without Firebase Auth, we allow read and write access to collections 
    // so that the database and simulated auth can synchronize properly.

    match /config/{configId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /sales/{saleId} {
      allow read, write: if true;
    }

    match /payouts/{payoutId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
