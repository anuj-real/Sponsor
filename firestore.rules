rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated (via background anonymous or custom auth)
    function isAuthenticated() {
      return request.auth != null;
    }

    match /config/{configId} {
      allow read: if true; // Public config can be read on mount
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      // Anyone can get a single user document by ID (for login credential checking)
      allow get: if true;
      // Listing, querying, and updating users requires authenticated state
      allow list: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /projects/{projectId} {
      allow read: if true; // Projects are publicly readable to display on loading
      allow write: if isAuthenticated();
    }

    match /sales/{saleId} {
      allow read, write: if isAuthenticated();
    }

    match /payouts/{payoutId} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }
  }
}
