rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // SBR Sponsors simplified access rules for custom passcode-authenticated clients.
    // Full read/write allowed so custom MLM portal can synchronize state, process bookings,
    // approve payouts, and manage passwords securely in the custom application layer.

    match /config/{configId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /sales/{saleId} {
      allow read, write: if true;
    }

    match /payouts/{payoutId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    match /user_logs/{logId} {
      allow read, write: if true;
    }
  }
}
